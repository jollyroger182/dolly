{
  "display_information": {
    "name": "dolly (dev)"
  },
  "features": {
    "bot_user": {
      "display_name": "dolly (dev)",
      "always_online": true
    },
    "shortcuts": [
      {
        "name": "Create a poll",
        "type": "global",
        "callback_id": "create_poll",
        "description": "Sends a poll in a channel"
      }
    ],
    "slash_commands": [
      {
        "command": "/dev-dolly",
        "description": "Launch a poll",
        "usage_hint": "[question]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:join",
        "channels:read",
        "chat:write",
        "commands",
        "reactions:read",
        "reactions:write",
        "groups:read",
        "mpim:read"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
